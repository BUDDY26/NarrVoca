# NarrVoca — Environment Variables Template
# Copy this file to .env.local and fill in your values before running locally.
# .env.local is listed in .gitignore and will never be committed.

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── OpenAI (story generation, definitions, audio, NarrVoca grading) ───────────
OPENAI_API_KEY=

# ── Google Gemini (writing practice, chatbox) ─────────────────────────────────
GEMINI_API_KEY=

# ── Fireworks AI (image generation) ──────────────────────────────────────────
FIREWORKS_API_KEY=

# ── App URL (used for OAuth redirects) ───────────────────────────────────────
NEXT_PUBLIC_NEXTAUTH_URL=http://localhost:3000

# ── Shared demo user (optional — used for public word-list previews) ──────────
NEXT_PUBLIC_SHARED_USER_ID=
